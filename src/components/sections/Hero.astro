---
// Hero.astro — Main section with GSAP entrance animation
import { Image } from "astro:assets";
import perfilImg from "../../assets/perfil.jpeg";
import Greeting from "../Greeting.astro";
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden section-padding"
>
  <!-- Decorative background -->
  <div
    class="absolute inset-0 -z-10
      bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,oklch(55%_0.22_25_/_0.15),transparent)]"
  >
  </div>

  <!-- Tech floating icons -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- React — top left -->
    <div
      class="tech-icon hidden sm:flex flex-col items-center absolute top-[16%] left-[6%]"
      style="opacity:0"
    >
      <svg width="44" height="44" viewBox="0 0 100 100" fill="none">
        <ellipse
          cx="50"
          cy="50"
          rx="46"
          ry="17"
          stroke="#61DAFB"
          stroke-width="5"></ellipse>
        <ellipse
          cx="50"
          cy="50"
          rx="46"
          ry="17"
          stroke="#61DAFB"
          stroke-width="5"
          transform="rotate(60 50 50)"></ellipse>
        <ellipse
          cx="50"
          cy="50"
          rx="46"
          ry="17"
          stroke="#61DAFB"
          stroke-width="5"
          transform="rotate(120 50 50)"></ellipse>
        <circle cx="50" cy="50" r="8" fill="#61DAFB"></circle>
      </svg>
      <span class="text-xs mt-1 font-medium" style="color:#61DAFB">React</span>
    </div>

    <!-- Node.js — top right -->
    <div
      class="tech-icon hidden sm:flex flex-col items-center absolute top-[13%] right-[7%]"
      style="opacity:0"
    >
      <svg width="44" height="44" viewBox="0 0 100 100" fill="none">
        <polygon
          points="50,4 93,27.5 93,72.5 50,96 7,72.5 7,27.5"
          stroke="#539E43"
          stroke-width="5"
          fill="none"></polygon>
        <text
          x="50"
          y="67"
          text-anchor="middle"
          fill="#539E43"
          font-size="42"
          font-weight="bold"
          font-family="monospace">N</text
        >
      </svg>
      <span class="text-xs mt-1 font-medium" style="color:#539E43">Node</span>
    </div>

    <!-- Astro — left middle -->
    <div
      class="tech-icon hidden sm:flex flex-col items-center absolute top-[44%] left-[3%]"
      style="opacity:0"
    >
      <svg width="44" height="44" viewBox="0 0 100 100" fill="none">
        <path
          d="M50 10 L80 88 L50 72 L20 88 Z"
          stroke="#FF5D01"
          stroke-width="5"
          fill="none"
          stroke-linejoin="round"></path>
        <path
          d="M34 60 L66 60"
          stroke="#FF5D01"
          stroke-width="5"
          stroke-linecap="round"></path>
      </svg>
      <span class="text-xs mt-1 font-medium" style="color:#FF5D01">Astro</span>
    </div>

    <!-- MongoDB — right middle -->
    <div
      class="tech-icon hidden sm:flex flex-col items-center absolute top-[40%] right-[4%]"
      style="opacity:0"
    >
      <svg width="44" height="44" viewBox="0 0 100 100" fill="none">
        <path
          d="M50 8 C50 8 76 38 76 60 C76 80 64 92 50 95 C36 92 24 80 24 60 C24 38 50 8 50 8Z"
          stroke="#47A248"
          stroke-width="5"
          fill="none"></path>
        <line
          x1="50"
          y1="72"
          x2="50"
          y2="95"
          stroke="#47A248"
          stroke-width="5"
          stroke-linecap="round"></line>
      </svg>
      <span class="text-xs mt-1 font-medium" style="color:#47A248">MongoDB</span
      >
    </div>

    <!-- Java — bottom left -->
    <div
      class="tech-icon hidden sm:flex flex-col items-center absolute bottom-[22%] left-[8%]"
      style="opacity:0"
    >
      <svg width="44" height="44" viewBox="0 0 100 100" fill="none">
        <path
          d="M22 35 L28 83 L72 83 L78 35 Z"
          stroke="#F89820"
          stroke-width="5"
          fill="none"
          stroke-linejoin="round"></path>
        <path
          d="M78 47 C96 47 96 67 78 67"
          stroke="#F89820"
          stroke-width="5"
          fill="none"
          stroke-linecap="round"></path>
        <path
          d="M38 32 Q41 20 44 32"
          stroke="#F89820"
          stroke-width="4"
          fill="none"
          stroke-linecap="round"></path>
        <path
          d="M54 32 Q57 20 60 32"
          stroke="#F89820"
          stroke-width="4"
          fill="none"
          stroke-linecap="round"></path>
      </svg>
      <span class="text-xs mt-1 font-medium" style="color:#F89820">Java</span>
    </div>

    <!-- SQL — bottom right -->
    <div
      class="tech-icon hidden sm:flex flex-col items-center absolute bottom-[20%] right-[6%]"
      style="opacity:0"
    >
      <svg width="44" height="44" viewBox="0 0 100 100" fill="none">
        <ellipse
          cx="50"
          cy="23"
          rx="32"
          ry="13"
          stroke="#336791"
          stroke-width="5"
          fill="none"></ellipse>
        <line x1="18" y1="23" x2="18" y2="77" stroke="#336791" stroke-width="5"
        ></line>
        <line x1="82" y1="23" x2="82" y2="77" stroke="#336791" stroke-width="5"
        ></line>
        <ellipse
          cx="50"
          cy="77"
          rx="32"
          ry="13"
          stroke="#336791"
          stroke-width="5"
          fill="none"></ellipse>
        <ellipse
          cx="50"
          cy="50"
          rx="32"
          ry="13"
          stroke="#336791"
          stroke-width="5"
          fill="none"></ellipse>
      </svg>
      <span class="text-xs mt-1 font-medium" style="color:#336791">SQL</span>
    </div>
  </div>

  <!-- Content -->
  <div class="container-section text-center">
    <div id="hero-eyebrow" class="opacity-0">
      <Greeting />
    </div>
    <br />
    <div>
      <Image
        src={perfilImg}
        alt="Andres Lopez"
        width={200}
        height={200}
        class="w-70 h-70 rounded-full mx-auto mb-4 object-cover object-top opacity-0"
        id="hero-eyebrow"
      />
    </div>

    <p
      id="hero-description"
      class="text-[var(--text-muted)] text-xl sm:text-xl max-w-xl mx-auto mb-10 opacity-0"
    >
      Systems engineer with 5+ years of experience building web & mobile
      applications with React, Node.js and more. Currently exploring how to
      harness <span class="text-gradient">AI</span> to craft smarter solutions.
    </p>

    <div id="hero-cta" class="flex flex-wrap gap-4 justify-center opacity-0">
      <a
        href="#about"
        class="px-8 py-3 rounded-full font-semibold text-sm
          bg-[var(--color-brand)] text-white
          hover:bg-[var(--color-brand-light)]
          transition-colors duration-200"
      >
        Explore
      </a>
      <a
        href="/src/assets/AndresLopezCV.pdf"
        target="_blank"
        class="px-8 py-3 rounded-full font-semibold text-sm
          bg-gradient-to-br from-[var(--color-brand-light)] to-[var(--color-gold)]
          text-white hover:opacity-90
          transition-opacity duration-200"
      >
        Download CV
      </a>
      <a
        href="#contact"
        class="px-8 py-3 rounded-full font-semibold text-sm
          border border-[var(--border)]
          text-[var(--text)]
          hover:border-[var(--color-brand)] hover:text-[var(--color-brand)]
          transition-colors duration-200"
      >
        Contact
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div
    id="scroll-indicator"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-0"
  >
    <span class="text-[var(--text-muted)] text-xs uppercase tracking-widest"
      >Scroll</span
    >
    <div
      class="w-px h-12 bg-gradient-to-b from-[var(--color-brand)] to-transparent"
    >
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";

  const tl = gsap.timeline({ delay: 0.2 });

  tl.to("#hero-eyebrow", {
    opacity: 1,
    y: 0,
    duration: 0.6,
    ease: "power3.out",
    from: { y: 20 },
  })
    .fromTo(
      "#hero-title",
      { opacity: 0, y: 40 },
      { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" },
      "-=0.3",
    )
    .fromTo(
      "#hero-description",
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" },
      "-=0.4",
    )
    .fromTo(
      "#hero-cta",
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.5, ease: "power3.out" },
      "-=0.3",
    )
    .fromTo(
      "#scroll-indicator",
      { opacity: 0 },
      { opacity: 1, duration: 0.6, ease: "power2.out" },
      "-=0.1",
    );

  // Tech icons: floating + fade in/out
  document.querySelectorAll(".tech-icon").forEach((icon, i) => {
    gsap.to(icon, {
      y: -(10 + i * 4),
      duration: 2.2 + i * 0.5,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut",
      delay: 2 + i * 0.4,
    });
    gsap.fromTo(
      icon,
      { opacity: 0 },
      {
        opacity: 0.6,
        duration: 2.5 + i * 0.4,
        repeat: -1,
        yoyo: true,
        ease: "power1.inOut",
        delay: 2 + i * 0.7,
      },
    );
  });

  // Continuous scroll indicator animation
  gsap.to("#scroll-indicator", {
    y: 8,
    duration: 1.4,
    repeat: -1,
    yoyo: true,
    ease: "sine.inOut",
    delay: 1.5,
  });
</script>
