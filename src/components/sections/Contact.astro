---
// Contact.astro — Sección de contacto con animación GSAP
---

<section id="contact" class="section-padding">
  <div class="container-section">
    <div
      class="
        contact-box
        relative rounded-3xl p-10 sm:p-16 text-center
        bg-[var(--surface)] border border-[var(--border)]
        overflow-hidden
      "
    >
      <!-- Fondo decorativo -->
      <div
        class="
          absolute inset-0 -z-10
          bg-[radial-gradient(ellipse_70%_60%_at_50%_100%,oklch(55%_0.22_25_/_0.1),transparent)]
        "
      ></div>

      <p class="contact-el text-[var(--color-brand)] text-sm font-semibold uppercase tracking-widest mb-4">
        Contacto
      </p>

      <h2 class="contact-el text-4xl sm:text-5xl font-black text-[var(--text)] mb-6 leading-tight">
        Hagamos algo<br />
        <span class="text-gradient">increíble juntos</span>
      </h2>

      <p class="contact-el text-[var(--text-muted)] text-lg max-w-md mx-auto mb-10">
        ¿Tienes un proyecto en mente? Escríbeme y empezamos a construirlo.
      </p>

      <a
        href="mailto:hola@ejemplo.com"
        class="
          contact-el
          inline-flex items-center gap-3
          px-10 py-4 rounded-full
          bg-[var(--color-brand)] text-white font-semibold
          hover:bg-[var(--color-brand-light)]
          transition-colors duration-200
          shadow-[0_4px_24px_oklch(55%_0.22_25_/_0.4)]
        "
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="2" y="4" width="20" height="16" rx="2" />
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
        </svg>
        Enviar mensaje
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  gsap.fromTo(
    '.contact-box',
    { opacity: 0, scale: 0.95, y: 40 },
    {
      opacity: 1,
      scale: 1,
      y: 0,
      duration: 0.8,
      ease: 'power3.out',
      scrollTrigger: { trigger: '#contact', start: 'top 75%' },
    }
  );

  gsap.fromTo(
    '.contact-el',
    { opacity: 0, y: 20 },
    {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: 'power3.out',
      stagger: 0.1,
      scrollTrigger: { trigger: '#contact', start: 'top 70%' },
    }
  );
</script>
